{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types", "./src/types"],

    "skipLibCheck": true,

    "sourceMap": true,

    "resolveJsonModule": true
  },
 "include": ["src/**/*", "src/types/express.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "prisma.config.ts",
  ]
}
